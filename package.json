    "probe:enquiry-reservation-gap": "node --env-file=.env scripts/probe-enquiry-reservation-gap.js",
    "probe:conversion-field-check": "node --env-file=.env scripts/probe-conversion-field-check.js",
    "probe:channel-flag-reliability": "node --env-file=.env scripts/probe-channel-flag-reliability.js"
