{
  "name": "cinch-portal-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cinch BI portal — Next.js app: serves the portal + pulls SiteLink into Supabase on a schedule",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "test:connection": "node --env-file=.env scripts/test-connection.js",
    "backfill": "node --env-file=.env scripts/backfill.js",
    "pull": "node --env-file=.env scripts/run-pull.js",
    "pull:snapshot": "node --env-file=.env scripts/run-pull-snapshot.js",
    "pull:cockpit": "node --env-file=.env scripts/run-pull-cockpit.js",
    "set:site-manager": "node --env-file=.env scripts/set-site-manager.js",
    "rebuild": "node --env-file=.env scripts/rebuild.js",
    "rebuild:as-of": "node --env-file=.env scripts/rebuild-as-of.js",
    "reparse": "node --env-file=.env scripts/reparse-report.js",
    "repull:month": "node --env-file=.env scripts/repull-report-month.js",
    "repull:all": "node --env-file=.env scripts/repull-report-all-months.js",
    "backfill:rentroll-gaps": "node --env-file=.env scripts/backfill-rentroll-gaps.js",
    "backfill:delinquent30": "node --env-file=.env scripts/backfill-delinquent30.js",
    "import:unit-status": "node --env-file=.env scripts/import-unit-status.js",
    "check": "node --env-file=.env scripts/check-payload.js",
    "init:sites": "node --env-file=.env scripts/init-sites.js",
    "invite": "node --env-file=.env scripts/invite-user.js",
    "test:stortrack": "node --env-file=.env scripts/test-stortrack.js",
    "probe:dm-groupkey": "node --env-file=.env scripts/probe-dm-groupkey-mismatch.js",
    "test:discounts": "node scripts/test-discounts-parser.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.45.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "soap": "^1.1.5",
    "xlsx": "^0.18.5"
  }
}
