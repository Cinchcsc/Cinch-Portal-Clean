{
  "name": "cinch-portal-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cinch BI portal — Next.js app: serves the portal + pulls SiteLink into Supabase on a schedule",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "test:connection": "node --env-file=.env scripts/test-connection.js",
    "backfill": "node --env-file=.env scripts/backfill.js",
    "pull": "node --env-file=.env scripts/run-pull.js",
    "pull:snapshot": "node --env-file=.env scripts/run-pull-snapshot.js",
    "pull:cockpit": "node --env-file=.env scripts/run-pull-cockpit.js",
    "rebuild:payload": "node --env-file=.env scripts/run-rebuild-payload.js",
    "rebuild": "node --env-file=.env scripts/rebuild.js",
    "rebuild:as-of": "node --env-file=.env scripts/rebuild-as-of.js",
    "reparse": "node --env-file=.env scripts/reparse-report.js",
    "repull:month": "node --env-file=.env scripts/repull-report-month.js",
    "repull:all": "node --env-file=.env scripts/repull-report-all-months.js",
